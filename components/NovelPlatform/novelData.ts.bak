// Novel Platform Data Schema & Versioning Store

export interface NovelParagraphVersion {
  version: string;
  content: string;
  note?: string;
  createdAt: string;
  author?: string;
}

export interface NovelParagraph {
  id: string;
  activeVersion: string;
  versions: Record<string, NovelParagraphVersion>;
  commentary?: string;
}

export interface NovelChapter {
  number: number;
  title: string;
  synopsis?: string;
  paragraphs: NovelParagraph[];
}

export interface NovelAct {
  number: number;
  title: string;
  summary?: string;
  theory?: string;
  story?: string;
  chapters: NovelChapter[];
}

export interface CharacterDetails {
  id: string;
  name: string;
  role: string;
  tagline: string;
  description: string;
}

export interface NovelDetails {
  id: string;
  slug: string;
  title: string;
  subtitle?: string;
  author: string;
  logline: string;
  synopsis: string;
  characters: CharacterDetails[];
  acts: NovelAct[];
  versionHistory: string[];
  updatedAt: string;
}

